# API Keys - Get these from the respective providers
TAVILY_API_KEY=your_tavily_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: If using OpenAI instead of Gemini
# OPENAI_API_KEY=your_openai_key_here

# Optional: Database URL for ChromaDB persistence
# CHROMA_DB_PATH=./chroma_db

# ============================================
# LLM Configuration (Flexible & Changeable)
# ============================================
# Supports: Gemini, OpenAI, Ollama, LM Studio, OpenRouter, Anthropic, Azure, etc.

# Default: Google Gemini (Free tier available)
AICALL_AI_PROVIDER=gemini
AICALL_AI_MODEL=gemini/gemini-1.5-flash
AICALL_AI_API_KEY=your_gemini_api_key_here
AICALL_AI_BASE_URL=

# --- Example Configurations ---

# Option 1: LM Studio (Local)
# AICALL_AI_PROVIDER=openai
# AICALL_AI_MODEL=qwen2.5-7b-instruct
# AICALL_AI_API_KEY=sk-dummy-key
# AICALL_AI_BASE_URL=http://localhost:1234/v1

# Option 2: Ollama (Local)
# AICALL_AI_PROVIDER=ollama
# AICALL_AI_MODEL=llama3.2
# AICALL_AI_API_KEY=
# AICALL_AI_BASE_URL=http://localhost:11434

# Option 3: OpenRouter (Multiple providers)
# AICALL_AI_PROVIDER=openrouter
# AICALL_AI_MODEL=anthropic/claude-3.5-sonnet
# AICALL_AI_API_KEY=your_openrouter_key
# AICALL_AI_BASE_URL=https://openrouter.ai/api/v1

# Option 4: Custom OpenAI-compatible endpoint
# AICALL_AI_PROVIDER=openai
# AICALL_AI_MODEL=qwen2.5-72b-instruct
# AICALL_AI_API_KEY=sk-V6Tu6Vo5R9CQ0WzCAcruOw
# AICALL_AI_BASE_URL=http://45.195.82.195:4000/v1

# Option 5: Anthropic Claude
# AICALL_AI_PROVIDER=anthropic
# AICALL_AI_MODEL=claude-3-5-sonnet-20241022
# AICALL_AI_API_KEY=your_anthropic_key
# AICALL_AI_BASE_URL=

# Option 6: Azure OpenAI
# AICALL_AI_PROVIDER=azure
# AICALL_AI_MODEL=azure/gpt-4
# AICALL_AI_API_KEY=your_azure_key
# AICALL_AI_BASE_URL=https://your-resource.openai.azure.com/
